VITE_API_BASE_URL=http://localhost:5000/api/v1

# Web application OAuth client ID (NOT Android/iOS/Desktop).
# In Google Cloud Console → Credentials → your OAuth client → Authorized JavaScript origins, add:
#   http://localhost:3000
# (must match window.location.origin exactly — no trailing slash)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
